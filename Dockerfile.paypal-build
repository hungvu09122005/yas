# ---- build stage: JDK 25 để compile (host chỉ có JDK 21) ----
FROM maven:3.9-eclipse-temurin-25 AS build
WORKDIR /app
COPY . .
RUN mvn -pl payment-paypal -am clean package -DskipTests

# ---- runtime stage: giống Dockerfile gốc ----
FROM eclipse-temurin:25-jre-alpine
COPY --from=build /app/payment-paypal/target/payment-paypal-1.0-SNAPSHOT.jar /app.jar
ENTRYPOINT ["java", "-jar", "/app.jar"]
