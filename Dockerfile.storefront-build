# ---- build stage: JDK 25 để compile (host chỉ có JDK 21) ----
FROM maven:3.9-eclipse-temurin-25 AS build
WORKDIR /app
COPY . .
RUN mvn -pl storefront-bff -am clean package -DskipTests

# ---- runtime stage: giống Dockerfile gốc ----
FROM eclipse-temurin:25-jre-alpine
COPY --from=build /app/storefront-bff/target/storefront-bff-1.0-SNAPSHOT.jar /app.jar
ENTRYPOINT ["java", "-jar", "/app.jar"]
