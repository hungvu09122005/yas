    repository: "file://../media"
  - name: order
    version: 0.2.0
    repository: "file://../order"
  - name: payment
    version: 0.2.0
    repository: "file://../payment"
  - name: payment-paypal
    version: 0.2.0
    repository: "file://../payment-paypal"
  - name: product
