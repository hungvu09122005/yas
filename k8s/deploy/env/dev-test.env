# Môi trường DEV-TEST — dùng cho job Jenkins developer_build (Mục 4)
# Jenkins sẽ ghi đè IMAGE_TAG=<commit-id> và IMAGE_REGISTRY=<registry fork> khi gọi:
#   IMAGE_TAG=$GIT_COMMIT IMAGE_REGISTRY=ghcr.io/devopschinh/yas ./deploy-env.sh dev-test
NAMESPACE=dev-test
DOMAIN=dev-test.yas.local.com
IMAGE_TAG=latest
IMAGE_REGISTRY=
